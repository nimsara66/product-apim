<?xml version="1.0" encoding="UTF-8"?>
<suite name="Cucumber Parity Baseline Suite" parallel="false" preserve-order="true">
    <listeners>
        <listener class-name="org.wso2.am.integration.cucumbertests.utils.listeners.ParallelToggleAlterSuiteListener"/>
        <listener class-name="org.wso2.am.integration.cucumbertests.utils.listeners.TestNameMdcListener"/>
    </listeners>

    <test name="ParityBaselineTests" preserve-order="true">
        <classes>
            <class name="org.wso2.am.integration.cucumbertests.runners.common.SystemInitializationRunner"/>
            <class name="org.wso2.am.integration.cucumbertests.runners.common.TenantUserInitializationRunner"/>
            <class name="org.wso2.am.integration.cucumbertests.runners.publisher.JWTTokenFormatRunner"/>
            <class name="org.wso2.am.integration.cucumbertests.runners.publisher.SubscriptionThrottlingPolicyRunner"/>
            <class name="org.wso2.am.integration.cucumbertests.runners.publisher.DevPortalSearchVisibilityRunner"/>
            <class name="org.wso2.am.integration.cucumbertests.runners.publisher.GraphQLApiBaselineRunner"/>
            <class name="org.wso2.am.integration.cucumbertests.runners.publisher.WebSocketApiBaselineRunner"/>
            <class name="org.wso2.am.integration.cucumbertests.runners.publisher.GovernancePolicyBaselineRunner"/>
            <!-- Shutdown must be the last class in this single test so it always runs after every
                 scenario. Keeping it in a separate <test> let it run in parallel (and out of order)
                 whenever the suite listener forces ParallelMode.TESTS, causing a null-container NPE. -->
            <class name="org.wso2.am.integration.cucumbertests.runners.common.SystemShutdown"/>
        </classes>
    </test>
</suite>
